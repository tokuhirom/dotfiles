[user]
	name = Tokuhiro Matsuno
	email = tokuhirom@gmail.com
	# signingkey はマシン固有のため ~/.gitconfig.local へ (ADR-0032)

[alias]
	branch-cleanup = "!git branch --merged | egrep -v \"main|master|develop\" | grep -v \\* | xargs -I % git branch -d %"
	prowl = "!gh prowl"
	ci = "commit -s"
	co = checkout
	st = status --short --branch
	br = branch
	tree = log --graph --pretty=oneline --abbrev-commit
	fetch-pulls = fetch origin +refs/pull/*:refs/remotes/pull/*
	# NOTE: 組み込みコマンドはエイリアスで上書きできないため commit = commit -s は無効。
	# Signed-off-by は core.hooksPath の prepare-commit-msg で付ける (ADR-0034)。

[color]
	ui = true

[core]
	editor = vim
	excludesfile = ~/.gitignore_global
	fsmonitor = true
	untrackedcache = true
	# DCO の Signed-off-by を全コミットに自動付与する (ADR-0034)。
	# グローバル hooksPath は各リポジトリの .git/hooks を無視するため、
	# hook-dispatch がローカル hook へチェーンする作りになっている。
	hooksPath = ~/.config/git/hooks

[init]
	defaultBranch = main

[submodule]
	recurse = true

[column]
	ui = auto

[branch]
	sort = -committerdate
	autosetuprebase = always

[tag]
	sort = version:refname

[merge]
	ff = false
	conflictstyle = zdiff3

[diff]
	noprefix = true
	algorithm = histogram
	colorMoved = plain
	mnemonicPrefix = true
	renames = true

[push]
	default = simple
	autoSetupRemote = true
	followTags = true

[fetch]
	prune = true
	pruneTags = true
	all = true

[help]
	autocorrect = prompt

[commit]
	verbose = true

[rerere]
	enabled = true
	autoupdate = true

[rebase]
	autoSquash = true
	autoStash = true
	updateRefs = true

[pull]
	rebase = true
[credential "https://github.com"]
    # helper =
    helper = !gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !/usr/bin/gh auth git-credential

# === コミット署名 (1Password の SSH 署名) ===
# 署名鍵・OS 依存の op-ssh-sign パス・gpgsign はマシン固有のため
# ~/.gitconfig.local に切り出している (ADR-0032)。
# テンプレート: config/.gitconfig.local.example / 生成: setup/setup-git-sign.sh
# 未設定のマシンでは下の include が黙って無視され、署名は行われない。
[include]
	path = ~/.gitconfig.local
